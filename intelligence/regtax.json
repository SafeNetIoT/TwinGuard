    "Delivery / Downloader": {
        "Direct Script Drop": {
          "end_goal": "Code Execution",
          "match_fields": ["http_uri", "http_body"],
          "patterns": [
            "\\.sh",
            "\\.exe",
            "\\.php",
            "wget\\s+https?://",
            "curl\\s+https?://"
          ]
        },
        "Drive-by Download / JS": {
          "end_goal": "User Exploitation",
          "match_fields": ["http_body"],
          "patterns": [
            "<iframe",
            "eval\\(atob\\(",
            "window\\.location",
            "document\\.location",
            "setTimeout\\(.*eval",
            "base64,"
          ]
        }
      },
    
      "Obfuscated / Anomalous Behavior": {
        "Junk Payload Flood": {
          "end_goal": "Resource Exhaustion",
          "match_fields": ["http_body", "http_uri"],
          "patterns": [
            "POST\\s.+",
            "garbled",
            "payload.{0,10}spam",
            "AAAAA+",
            "[A-Z]{100,}",
            "[0-9]{100,}"
          ]
        },
        "Unknown Pattern": {
          "end_goal": "Undiscovered Variant",
          "match_fields": ["http_body", "http_uri"],
          "patterns": [
            "[a-zA-Z0-9+/=]{200,}",
            "[a-f0-9]{32,}",
            "entropy",
            "anomaly",
            "randomized",
            "X-Obfuscated",
            "X-Custom"
          ]
        }
      }
}
