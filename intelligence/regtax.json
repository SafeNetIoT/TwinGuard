{
    "Exploit Attempts": {
      "File Inclusion (LFI/RFI)": {
        "end_goal": "Code Execution",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "\\?file=.*",
          "\\?path=.*",
          "\\?url=https?://.*",
          "wp_abspath=",
          "\\.\\./",
          "%2e%2e"
        ]
      },
      "Misconfiguration Exploit": {
        "end_goal": "Priv Esc / Info Leak",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "\\.env",
          "\\.bak",
          "/setup\\.php",
          "xmlrpc\\.php",
          "/\\.git/",
          "/config(\\.php)?",
          "/backup/",
          "/readme\\.html",
          "/changelog\\.txt"
        ]
      },
      "REST/JSON Abuse": {
        "end_goal": "Data Leak / Enumeration",
        "match_fields": ["http_uri"],
        "patterns": [
          "/wp-json/",
          "/api/",
          "/wp-json/wp/v2/",
          "/api/v[0-9]+/"
        ]
      },
      "SQL Injection (SQLi)": {
        "end_goal": "DB Access / Bypass",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "(?i)select.+from",
          "(?i)union.+select",
          "\\bor\\s+1=1\\b",
          "--",
          "%27",
          "%3D",
          "\\bselect\\b",
          "\\binformation_schema\\b"
        ]
      },
      "Command Injection": {
        "end_goal": "Code Execution",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "cmd=",
          "system\\(",
          ";\\s*(wget|curl|bash)",
          "&&",
          "\\|\\|",
          "python\\s+-c",
          "bash\\s+-i",
          "nc\\s+-e"
        ]
      },
      "Denial of Service (DoS)": {
        "end_goal": "Resource Exhaustion",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "xmlrpc\\.php",
          "pingback\\.ping",
          "/\\.well-known/",
          "Content-Length: \\d{7,}",
          "slowloris",
          "\\.zip",
          "/flood",
          "keep-alive"
        ]
      }
    },
  
    "Web Shell / Payload Upload": {
      "Simple Shell Upload": {
        "end_goal": "Persistent Access",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "\\.php",
          "cmd=",
          "system\\(",
          "shell\\.php",
          "r57\\.php",
          "c99\\.php"
        ]
      },
      "Obfuscated Shell Upload": {
        "end_goal": "Stealth Backdoor",
        "match_fields": ["http_body"],
        "patterns": [
          "eval\\(base64_decode\\(",
          "base64_decode\\(",
          "gz(inflate|uncompress)\\(",
          "str_rot13\\(",
          "hex2bin\\("
        ]
      },
      "Two-Stage Payload": {
        "end_goal": "Loader & Dropper",
        "match_fields": ["http_uri", "http_body"],
        "patterns": [
          "upload",
          "/shell\\.php\\?cmd=",
          "wget\\s+http",
          "curl\\s+-o",
          "chmod\\s+\\+x"
        ]
      }
    },

